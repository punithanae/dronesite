# ===========================================
# PUNITHAN DRONE WEBSITE - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# RESEND EMAIL CONFIGURATION
# ===========================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Email address to receive consultation notifications
NOTIFICATION_EMAIL=punithan@example.com

# ===========================================
# GOOGLE reCAPTCHA v3
# ===========================================
# Get keys from: https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ===========================================
# TWILIO (OPTIONAL - for WhatsApp notifications)
# ===========================================
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ===========================================
# SITE CONFIGURATION
# ===========================================
NEXT_PUBLIC_SITE_URL=https://punithandronepilot.com
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps/embed?pb=YOUR_EMBED_URL

# ===========================================
# CONTACT INFORMATION
# ===========================================
NEXT_PUBLIC_PHONE=+91 XXXXX XXXXX
NEXT_PUBLIC_EMAIL=contact@punithandronepilot.com
NEXT_PUBLIC_WHATSAPP=+91XXXXXXXXXX
NEXT_PUBLIC_ADDRESS=Ahmedabad, Gujarat, India
NEXT_PUBLIC_DGCA_LICENSE=DGCA-XXXXX-XXXX
